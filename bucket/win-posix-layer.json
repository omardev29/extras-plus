{
    "version": "main",
    "description": "A POSIX layer with Linux-like methods for PowerShell on Windows",
    "homepage": "https://github.com/omardev29/win-posix-layer",
    "license": "MIT",
    "url": "https://github.com/omardev29/win-posix-layer/archive/refs/heads/main.zip",
    "hash": "99118edbe19cee015f384356f409cd3ae8f7465892e0dc5f74b2449ef9a0372e",
    "extract_dir": "win-posix-layer-main",
    "pre_install": [
        "Get-ChildItem \"$dir\" -Recurse | Where-Object { $_.Name -match '^(LICENSE|README\\.md)$' } | Remove-Item -Force -ErrorAction SilentlyContinue"
    ],
    "post_install": [
        "$profileDir = \"$env:USERPROFILE\\Documents\\PowerShell\"",
        "if (-not (Test-Path $profileDir)) { New-Item -ItemType Directory -Path $profileDir -Force | Out-Null }",
        "$profilePath = \"$profileDir\\Microsoft.PowerShell_profile.ps1\"",
        "$modulePath = (Get-ChildItem \"$dir\" -Filter \"WinPosixLayer.psd1\" -Recurse | Select-Object -First 1).FullName",
        "if (-not $modulePath) { $modulePath = \"$dir\\WinPosixLayer.psd1\" }",
        "if (Test-Path $profilePath) {",
        "    $content = Get-Content $profilePath -Raw",
        "    if ($content -notmatch [regex]::Escape(\"Import-Module \\\"$modulePath\\\"\")) {",
        "        Add-Content $profilePath \"`nImport-Module \\\"$modulePath\\\"\"",
        "    }",
        "} else {",
        "    Set-Content $profilePath \"Import-Module \\\"$modulePath\\\"\"",
        "}"
    ],
    "bin": [],
    "notes": "The module has been added to your PowerShell profile. Restart PowerShell or run . $PROFILE to load it. External tools like eza, bat, ripgrep, duf, zoxide, and superfile are recommended for full functionality."
}
